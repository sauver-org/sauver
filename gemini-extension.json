{
  "name": "sauver",
  "version": "0.1.0",
  "description": "Sauver: The digital bouncer for your inbox.",
  "mcpServers": {
    "sauver": {
      "command": "uv",
      "args": [
        "run",
        "src/main.py"
      ]
    },
    "google-workspace": {
      "command": "npx",
      "args": [
        "-y",
        "@googleworkspace/mcp-server"
      ]
    }
  },
  "contextFileName": "GEMINI.md"
}